{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aanote",
  "version": "0.1.0",
  "identifier": "com.floatcreatives.aanote",
  "build": {
    "beforeDevCommand": "python3 -m http.server 1420 --directory dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "mkdir -p dist/js dist/css && cp index.html dist/index.html && cp -r js/. dist/js/ && cp -r css/. dist/css/",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "aanote",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "dmg"],
    "icon": [
      "icons/icon.png"
    ]
  }
}
